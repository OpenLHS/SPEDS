  "properties": {
    "header": {
      "description": "The header of a SPEDS message. Mandatory in all layers.",
      "type": "object",
      "properties": {
        "msgtype": {
          "description": "The type of a SPEDS message. Mandatory in all layers.",
          "type": "string",
          "enum": [
            "SES.PUB.ENV",
            "SES.PUB.REC",
            "SES.CLE.ENV",
            "SES.CLE.REC",
            "SES.SAK.ENV",
            "SES.SAK.REC",
            "SES.MSG.ENV",
            "SES.MSG.REC",
            "SES.FIN.ENV",
            "SES.FIN.REC"
          ]
        },
        "id": {
          "description": "The identifier of a SPEDS message. Mandatory in all layers.",
          "type": "string",
          "format": "uuid"
        },
        "parameters": {
          "description": "The parameters of the Session layer.",
          "oneOf": [
            {
              "const": false
            },
            {
              "type": "object",
              "minProperties": 1
            }
          ]
        },
        "version": {
          "type": "object",
          "properties": {
            "number": {
              "description": "The version of the current layer.",
              "$ref": "#/$defs/versioning"
            },
            "reference": {
              "description": "The reference of the present version of the layer.",
              "type": "string",
              "format": "iri"
            }
          },
          "required": [
            "number",
            "reference"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "msgtype",
        "id",
        "parameters",
        "version"
      ]
    },
    "stamp": {
      "description": "The authentification seal (the stamp) of the sender of this message.",
      "$ref": "#/$defs/bytestring"
    },
    "content": {
      "description": "The content of a SPEDS message. Mandatory in all layers.",
      "oneOf": [
        {
          "$ref": "#/$defs/bytestring"
        },
        {
          "$ref": "#/$defs/uuid"
        },
        {
          "type": "object",
          "minProperties": 1
        }
      ]
    }
  },
  "required": [
    "header",
    "stamp",
    "content"
  ],
  "additionalProperties": false
}