{
  "$id": "https://griis.ca/speds/json/schema/v7.0.0/pdu/ProtocolDataUnit-2-PRE.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProtocolDataUnit-2-PRE (2025-11-28T10:00:00-0500)",
  "$defs": {
    "iri": {
      "description": "A valid IR according to RFC 3987",
      "type": "string",
      "format": "iri"
    },
    "uuid": {
      "description": "A valid UUID according to RFC 4122",
      "type": "string",
      "format": "uuid"
    },
    "bytestring": {
      "description": "A base-64 encoded bytestring",
      "type": "string",
      "contentEncoding": "base64"
    },
    "versioning": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)(\\.[0-9]+[a-z]*)$"
    }
  },
  "description": "For the Presentation Layer of SPEDS (Layer 2) : a unit of data which is transferred from one end of a connection to the other with no loss of identity or meaning.",
  "type": "object",
  "javaType": "ProtocolDataUnit2Pre",
  "examples": [
    {
      "header": {
        "msgtype": "PRE.MSG.ENV",
        "id": "ba62cebf-e9fa-4472-b776-49cbf04ab32a",
        "parameters": false,
        "version": {
          "number": "6.1.0",
          "reference": "https://www.griis.ca/speds/layer/ses/v6.1.0/reference"
        }
      },
      "content": "TUVnQ1FRQ285K0JwTVJZUS9kTDNEUzJDeUp4UkYrajZjdGJUMy9RcDg0K0tlRmhuaWk3TlQ3ZkVMaWxLVVNueApTMzBXQXZRQ0NvMnlVMW9yZmdxcjQxbU03ME1CQWdNQkFBRT0="
    }
  ],
  "properties": {
    "header": {
      "description": "The header of a SPEDS message. Mandatory in all layers.",
      "type": "object",
      "properties": {
        "msgtype": {
          "description": "The type of a SPEDS message. Mandatory in all layers.",
          "type": "string",
          "enum": [
            "PRE.MSG.ENV"
          ]
        },
        "id": {
          "description": "The identifier of a SPEDS message. Mandatory in all layers.",
          "$ref": "#/$defs/uuid"
        },
        "parameters": {
          "description": "The parameters of the Presentation layer.",
          "oneOf": [
            {
              "const": false
            },
            {
              "type": "object",
              "minProperties": 1
            }
          ]
        },
        "version": {
          "type": "object",
          "properties": {
            "number": {
              "description": "The version of the current layer.",
              "$ref": "#/$defs/versioning"
            },
            "reference": {
              "description": "The reference of the present version of the layer.",
              "type": "string",
              "format": "iri"
            }
          },
          "required": [
            "number",
            "reference"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "msgtype",
        "id",
        "parameters",
        "version"
      ]
    },
    "content": {
      "description": "The content of a SPEDS message. Mandatory in all layers.",
      "type": "string"
    }
  },
  "required": [
    "header",
    "content"
  ],
  "additionalProperties": false
}
